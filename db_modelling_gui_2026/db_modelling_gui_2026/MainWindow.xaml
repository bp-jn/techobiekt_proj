<Window x:Class="db_modelling_gui_2026.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:db_modelling_gui_2026.ViewModels"
        Title="Projekt Technologie Obiektowe" Height="400" Width="600">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
            <TextBlock Text="Tabele" FontWeight="Bold" Margin="5"/>

            <ListBox ItemsSource="{Binding Tables}"
                     SelectedItem="{Binding SelectedTable}"
                     DisplayMemberPath="Name"
                     Height="200"/>

            <Button Content="Dodaj tabelę"
                    Command="{Binding AddTableCommand}"
                    Margin="5"/>

            <Button Content="Usuń tabelę"
                    Command="{Binding RemoveTableCommand}"
                    Margin="5"/>
        </StackPanel>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Szczegóły tabeli" FontWeight="Bold"/>

            <TextBox Text="{Binding SelectedTable.Name, UpdateSourceTrigger=PropertyChanged}"
                     Margin="5"/>
        </StackPanel>

    </Grid>
</Window>